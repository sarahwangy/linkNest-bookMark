generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  emailVerified      DateTime?
  name               String?
  image              String?
  createdAt          DateTime  @default(now())
  driveConnected     Boolean   @default(false)
  driveRefreshToken  String?

  accounts      Account[]
  bookmarks     Bookmark[]
  syncEvents    SyncEvent[]
  conversations Conversation[]
  settings      UserSettings?
  tokens        ApiToken[]

  // NextAuth
  authAccounts  AuthAccount[]
  sessions      Session[]
}

model AuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  name       String
  tokenHash  String    @unique
  prefix     String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id         String    @id @default(cuid())
  userId     String
  label      String
  browser    String
  color      String?
  createdAt  DateTime  @default(now())
  lastSyncAt DateTime?

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookmarks  Bookmark[]
  syncEvents SyncEvent[]

  @@unique([userId, label])
}

model Bookmark {
  id            String    @id @default(cuid())
  userId        String
  accountId     String
  url           String
  urlNormalized String
  title         String
  folder        String?
  addDate       DateTime
  favicon       String?
  ogTitle       String?
  ogDescription String?
  ogImage       String?
  summary       String?
  aiCategory    String?
  aiTags        String[]
  httpStatus    Int?
  finalUrl      String?
  lastCheckedAt DateTime?
  isDead        Boolean   @default(false)
  clickCount    Int       @default(0)
  lastClickedAt DateTime?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  account   Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  embedding BookmarkEmbedding?

  @@unique([accountId, urlNormalized])
  @@index([userId, urlNormalized])
  @@index([userId, aiCategory])
  @@index([userId, isDead])
  @@index([userId, addDate])
}

model BookmarkEmbedding {
  bookmarkId String @id
  embedding  Unsupported("vector(1536)")

  bookmark Bookmark @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)
}

model SyncEvent {
  id           String   @id @default(cuid())
  userId       String
  accountId    String
  mode         String
  itemsAdded   Int      @default(0)
  itemsUpdated Int      @default(0)
  itemsDeleted Int      @default(0)
  status       String
  errorMessage String?
  syncedAt     DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId, syncedAt])
  @@index([accountId, syncedAt])
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  title     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  messages Message[]
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id               String   @id @default(cuid())
  conversationId   String
  role             String
  content          String
  citedBookmarkIds String[]
  createdAt        DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model UserSettings {
  userId          String  @id
  enableSummary   Boolean @default(true)
  enableDeadCheck Boolean @default(true)
  emailDigest     Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
