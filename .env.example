# Database (Neon Postgres — create project at neon.tech, copy connection string)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth (generate secret: openssl rand -base64 32)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"

# Google OAuth (console.cloud.google.com → APIs → Credentials → OAuth 2.0 Client IDs)
# Authorized redirect URI: https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Inngest (inngest.com — get keys from your app dashboard)
INNGEST_SIGNING_KEY=""
INNGEST_EVENT_KEY=""
